-    gDoProfileReset = false;
-    gDoMigration = false;
-  }
-
-  if (gDoProfileReset && !*aProfile) {
-    NS_WARNING("Profile reset is only supported for named profiles.");
+  // Patch: Always use 'userData' folder next to EXE for portable profile
+  nsCOMPtr<nsIFile> exeDir;
+  nsresult dirRv = NS_GetSpecialDirectory(NS_GRE_BIN_DIR, getter_AddRefs(exeDir));
+  if (NS_FAILED(dirRv) || !exeDir) {
+    NS_WARNING("Failed to get executable directory for portable profile.");
